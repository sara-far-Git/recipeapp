# ===========================
# Database
# ===========================
POSTGRES_USER=recipeapp
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=recipeapp_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://recipeapp:changeme_in_production@localhost:5432/recipeapp_db

# ===========================
# Backend / FastAPI
# ===========================
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true

# Production CORS — set to your Vercel/Render frontend URL
FRONTEND_URL=

# ===========================
# Frontend / Next.js
# ===========================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=RecipeApp

# ===========================
# AI Integration
# ===========================
OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# ===========================
# Storage (choose one)
# ===========================
# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=recipeapp-images
AWS_REGION=us-east-1

# OR Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===========================
# pgAdmin (local dev only)
# ===========================
PGADMIN_EMAIL=admin@recipeapp.com
PGADMIN_PASSWORD=admin
