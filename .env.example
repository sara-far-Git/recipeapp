# ===========================
# Database
# ===========================
POSTGRES_USER=recipeapp
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=recipeapp_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://recipeapp:changeme_in_production@localhost:5432/recipeapp_db

# ===========================
# Backend / FastAPI
# ===========================
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true

# Production CORS — set to your Vercel/Render frontend URL
FRONTEND_URL=

# ===========================
# Frontend / Next.js
# ===========================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=RecipeApp
# Google OAuth client ID (the web client created in Google Cloud Console).
# Must match GOOGLE_CLIENT_ID below — the frontend obtains the id_token,
# the backend verifies it against the same audience.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ===========================
# Google OAuth (backend)
# ===========================
# Same client ID as NEXT_PUBLIC_GOOGLE_CLIENT_ID. Required for /auth/google.
GOOGLE_CLIENT_ID=

# ===========================
# Monitoring (Sentry)
# ===========================
# Leave blank to disable Sentry entirely.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_DSN=

# ===========================
# Rate limiting (per-IP)
# ===========================
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_AI=20/hour

# ===========================
# AI Integration
# ===========================
OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# ===========================
# Storage (choose one)
# ===========================
# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=recipeapp-images
AWS_REGION=us-east-1

# OR Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===========================
# pgAdmin (local dev only)
# ===========================
PGADMIN_EMAIL=admin@recipeapp.com
PGADMIN_PASSWORD=admin
